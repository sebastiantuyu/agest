{
  "name": "@sebastiantuyu/agest",
  "version": "0.2.2",
  "description": "A testing library for agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastiantuyu/agest.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx examples/basic.test.ts",
    "test:examples": "tsx examples/basic.test.ts && tsx examples/agent.test.ts",
    "stats": "tsx src/stats.ts",
    "preview": "tsx src/preview.ts",
    "site:preview": "npx serve site -p 3000",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/openai": "^1.4.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3",
    "dotenv": "^17.4.1",
    "langchain": "^1.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@supercharge/promise-pool": "^3.3.0"
  }
}
